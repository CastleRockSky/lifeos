# LifeOS Environment Configuration
# Copy to .env and fill in values

# PostgreSQL
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Anthropic (for Phase 2 AI analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Security
SECRET_KEY=change-me-to-a-random-string

# Data path on host
DATA_PATH=/srv/lifeos

# Email forwarding ingestion (Phase 3)
# Leave IMAP_ENABLED=false until you've populated the credentials below.
# For Gmail/Workspace: enable 2FA on the account, then create an App Password
# (https://myaccount.google.com/apppasswords) and use it as IMAP_PASSWORD.
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=docs@example.com
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL=120
IMAP_PROCESSED_LABEL=LifeOS/Processed
IMAP_FAILED_LABEL=LifeOS/Failed

# Google Calendar sync (Phase 10)
# 1. Drop OAuth client JSON at /srv/lifeos/auth/google-oauth-client.json
# 2. Run: docker exec -it lifeos-api python scripts/bootstrap_google_calendar.py
# 3. Flip GOOGLE_CALENDAR_ENABLED to true and restart api
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_PATH=/data/auth/google-calendar-tokens.json
GOOGLE_OAUTH_CLIENT_PATH=/data/auth/google-oauth-client.json
GOOGLE_CALENDAR_DOMAINS=
GOOGLE_CALENDAR_LINK_BASE=

# Azure Blob off-site backup (optional, used by scripts/backup.sh)
# Generate a container-scoped SAS in the Azure portal:
#   Storage account → Containers → <container> → "Generate SAS"
#   Permissions:  Read, Add, Create, Write, List
#   Expiry:       1 year (or your preference)
#   Protocols:    HTTPS only
# Copy the SAS *token* (the query string, with or without the leading '?').
AZURE_STORAGE_ACCOUNT=
AZURE_CONTAINER=
AZURE_SAS_TOKEN=
# Optional path prefix inside the container, e.g. "nightly" or "hostname/nightly"
AZURE_BLOB_PREFIX=

# Backblaze B2 off-site backup (optional, used by scripts/backup.sh)
# Independent of the Azure leg above — set either, both, or neither.
# Create a bucket, then an Application Key scoped to it:
#   Backblaze account → Application Keys → "Add a New Application Key"
#   Allow access to:  the backup bucket
#   Capabilities:     listBuckets, listFiles, readFiles, writeFiles
# Copy the keyID and applicationKey (the key is shown only once).
# Upload uses rclone's native B2 backend (installed by install-backup-cron.sh).
B2_BUCKET=
B2_KEY_ID=
B2_APPLICATION_KEY=
# Optional path prefix inside the bucket, e.g. "nightly" or "hostname/nightly"
B2_PREFIX=

# MCP server (OpenClaw / Claude integration)
# Issue with: docker exec -it lifeos-api python scripts/bootstrap_agent_key.py \
#                  --name OpenClawMCP --domains '*'
# Used for BOTH inbound MCP auth and outbound calls from MCP → /api/agent/*
MCP_AGENT_KEY=
# DNS-rebinding protection: blank disables the Host header check (LAN trust
# mode, agent key is the gate). To re-enable with a strict allowlist, set
# to a comma-separated list of hostnames/IPs that clients use:
#   MCP_ALLOWED_HOSTS=lifeos.local,10.0.0.92,localhost
MCP_ALLOWED_HOSTS=
