# LifeOS Environment Configuration
# Copy to .env and fill in values

# PostgreSQL
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Anthropic (for Phase 2 AI analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Security
SECRET_KEY=change-me-to-a-random-string

# Data path on host
DATA_PATH=/srv/lifeos

# Email forwarding ingestion (Phase 3)
# Leave IMAP_ENABLED=false until you've populated the credentials below.
# For Gmail/Workspace: enable 2FA on the account, then create an App Password
# (https://myaccount.google.com/apppasswords) and use it as IMAP_PASSWORD.
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=docs@example.com
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL=120
IMAP_PROCESSED_LABEL=LifeOS/Processed
IMAP_FAILED_LABEL=LifeOS/Failed
